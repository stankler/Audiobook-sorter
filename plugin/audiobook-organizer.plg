<?xml version='1.0' standalone='yes'?>
<!DOCTYPE PLUGIN [
  <!ENTITY name      "audiobook-organizer">
  <!ENTITY author    "stankler">
  <!ENTITY version   "2026.04.30.4">
  <!ENTITY pluginURL "https://raw.githubusercontent.com/stankler/Audiobook-sorter/main/plugin/audiobook-organizer.plg">
  <!ENTITY pluginDir "/boot/config/plugins/&name;">
  <!ENTITY emhttp    "/usr/local/emhttp/plugins/&name;">
]>
<PLUGIN name="&name;" author="&author;" version="&version;" pluginURL="&pluginURL;"
        support="https://github.com/stankler/Audiobook-sorter/issues">

<CHANGES>
###2026.04.30.4
- Fix STT title parsing: "written by", "narrated by", "read by" no longer included in title

###2026.04.30.3
- STT file picker: choose which audio file to transcribe when book has multiple files

###2026.04.30.2
- STT transcription parses "presents X by Y" to extract title and author
- Queries Google Books and Open Library with STT-extracted title/author as candidates

###2026.04.30.1
- Remove moved books from queue list immediately
- rc script recreates container on image change (fixes stale daemon after update)

###2026.04.30
- Show actual error details in move failure alert

###2026.04.29.8
- Logs tab now reads /config/audiobook-organizer.log directly from disk
- Logs tab visible even when daemon is down; auto-scrolls to bottom

###2026.04.29.3
- Move entire source folder contents (subdirs, artwork, etc.), not just scanned files

###2026.04.29.2
- Fix folder browser crashing when configured path doesn't exist; falls back to /mnt

###2026.04.29.1
- Show plugin version on config page

###2026.04.29
- Per-file move progress tracking in UI
- All files in book folder now moved (covers, NFOs, etc.), not just audio
- Empty source directories cleaned up after moves
- Claude candidate dedup fix

###2025.04.26
- Initial release.
</CHANGES>

<!-- Download and install UI files + rc script -->
<FILE Name="&pluginDir;/audiobook-organizer-&version;.txz" Run="upgradepkg --install-new">
<URL>https://github.com/stankler/Audiobook-sorter/releases/download/&version;/audiobook-organizer-&version;.txz</URL>
</FILE>

<!-- Pull Docker image and start daemon -->
<FILE Name="&pluginDir;/post-install.sh" Run="bash">
<INLINE>
#!/bin/bash
IMAGE="ghcr.io/stankler/audiobook-organizer:latest"
echo "Pulling Audiobook Organizer Docker image..."
docker pull "${IMAGE}" || { echo "ERROR: docker pull failed"; exit 1; }
/etc/rc.d/rc.audiobook-organizer start
echo "Audiobook Organizer installed. Open Tools > Audiobook Organizer."
</INLINE>
</FILE>

</PLUGIN>
